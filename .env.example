# ── 本地 Demo 用設定（local 分支）──────────────
# 預設假設：單機有 NVIDIA GPU（llm 必須吃 GPU）
# 使用方式：cp .env.example .env 後依需求修改

# ── Whisper 語音辨識 ──────────────────────────
STREAM_MODEL=phate334/Breeze-ASR-25-ct2
# DEVICE=auto 會自動偵測 CUDA；無 GPU 時自動回 cpu
# 想把 GPU 完全留給 llm，可手動設 cpu
DEVICE=auto
COMPUTE_TYPE=int8          # int8 / float16 / float32
DEFAULT_LANGUAGE=zh

# whisper.cpp 模式（AMD GPU / Vulkan；NVIDIA 用戶免設）
WHISPER_CPP_URL=
WHISPER_CPP_TIMEOUT=30

# ── 後端 VAD ──────────────────────────────────
BACKEND_VAD_ENABLED=true
BACKEND_VAD_THRESHOLD=0.3
BACKEND_VAD_SILENCE_MS=300
BACKEND_VAD_SPEECH_PAD_MS=200

# ── LLM 報告服務 ──────────────────────────────
LLM_MODEL=MediaTek-Research/Breeze-2-8B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# ── CORS ──────────────────────────────────────
# Demo 用全開；正式部署請改為具體網域
CORS_ORIGINS=*
