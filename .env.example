# ── Whisper 轉錄 ──────────────────────────────
STREAM_MODEL=phate334/Breeze-ASR-25-ct2
DEVICE=auto                # auto / cpu / cuda
COMPUTE_TYPE=int8          # int8 / float16 / float32
DEFAULT_LANGUAGE=zh

# whisper.cpp 模式（設定後優先使用，否則使用 faster-whisper）
WHISPER_CPP_URL=           # e.g. http://localhost:8080/inference
WHISPER_CPP_TIMEOUT=30

# ── 後端 VAD ──────────────────────────────────
BACKEND_VAD_ENABLED=true
BACKEND_VAD_THRESHOLD=0.3
BACKEND_VAD_SILENCE_MS=300
BACKEND_VAD_SPEECH_PAD_MS=200

# ── LLM 報告服務 ──────────────────────────────
LLM_MODEL=MediaTek-Research/Breeze-2-8B-Instruct
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=120

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=*             # 多個來源以逗號分隔，e.g. http://localhost:3000,https://example.com
